DATABASE_URL=postgres://your-username@localhost:5432/pantry_host
AI_PROVIDER=anthropic
AI_API_KEY=

# recipe-api.com key (optional). When set, the self-hosted app shows a
# "Recipe API" tab on the Import Recipes page with structured recipes,
# USDA nutrition data, and dietary flags. Grab a free-tier key at
# https://recipe-api.com/pricing — 100 req/day / 10 req/min. The key is
# served to the Rex client via an owner-gated /api/recipe-api-key route
# and never injected into guest-mode HTML.
# RECIPE_API_KEY=rapi_...

# Pixabay fallback images for recipe cards (optional). When set, recipes
# without their own photo will display a borrowed landscape photo from
# Pixabay with courtesy photographer attribution. Pixabay Content License:
# attribution optional, free to use. Rate limit: 100 req/min. Sign up at
# https://pixabay.com/api/docs/ for a free key.
# PIXABAY_API_KEY=
# PIXABAY_FALLBACK_ENABLED=true  # default true; feature is dormant without a key

# Rex's V8 SSR fetch polyfill blocks every private/loopback IP as SSRF
# protection (see crates/rex_v8/src/fetch.rs in @limlabs/rex). getServerSideProps
# on /recipes/[slug] calls the standalone GraphQL server over HTTP to hydrate
# initial recipe data + OG tags; without this allowlist entry the fetch throws
# "fetch blocked: 127.0.0.1 resolves to a private address" and pages render
# with an empty <main> + default "Pantry Host" og:title. Must match the URL
# prefix used in the GSSP fetch.
REX_INTERNAL_ORIGIN=http://127.0.0.1:4001

# Feature flags (all default to true)
# ENABLE_IMAGE_PROCESSING=false  # Skip sharp variants on upload, save disk space (Pi)
SHOW_COCKTAILDB=true              # Set to false to hide the TheCocktailDB tab on /recipes/import.
                                  # The Settings page at /settings can also toggle this — overrides
                                  # are written to packages/app/.settings-overrides.json and layered
                                  # on top of this value at request time (no server restart needed).
