DATABASE_URL=postgres://your-username@localhost:5432/pantry_host
AI_PROVIDER=anthropic
AI_API_KEY=

# recipe-api.com key (optional). When set, the self-hosted app shows a
# "Recipe API" tab on the Import Recipes page with structured recipes,
# USDA nutrition data, and dietary flags. Grab a free-tier key at
# https://recipe-api.com/pricing — 100 req/day / 10 req/min. The key is
# served to the Rex client via an owner-gated /api/recipe-api-key route
# and never injected into guest-mode HTML.
# RECIPE_API_KEY=rapi_...

# Feature flags (all default to true)
# ENABLE_IMAGE_PROCESSING=false  # Skip sharp variants on upload, save disk space (Pi)
SHOW_COCKTAILDB=true              # Set to false to hide the TheCocktailDB tab on /recipes/import.
                                  # The Settings page at /settings can also toggle this — overrides
                                  # are written to packages/app/.settings-overrides.json and layered
                                  # on top of this value at request time (no server restart needed).
